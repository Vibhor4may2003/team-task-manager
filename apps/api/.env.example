PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/team-task-manager
JWT_SECRET=change-me-in-production
# Optional token TTL in seconds (defaults to 604800 = 7 days)
JWT_EXPIRES_SECONDS=604800
# Optional code that promotes a signup to Admin. The very first signup is also auto-promoted.
ADMIN_SIGNUP_CODE=
# Optional comma-separated list of allowed CORS origins (only needed when API and web are on different hosts)
# CORS_ORIGIN=https://your-web.up.railway.app
