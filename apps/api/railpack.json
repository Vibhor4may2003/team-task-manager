{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22",
    "pnpm": "9"
  },
  "steps": {
    "install": {
      "commands": ["pnpm install --frozen-lockfile"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["pnpm --filter @ttm/api run build"]
    }
  },
  "deploy": {
    "startCommand": "node apps/api/dist/index.js"
  }
}
