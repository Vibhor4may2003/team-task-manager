{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22",
    "pnpm": "9"
  },
  "steps": {
    "install": {
      "commands": ["pnpm install --frozen-lockfile"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["pnpm --filter @ttm/web run build"]
    }
  },
  "deploy": {
    "startCommand": "sh -c 'pnpm --filter @ttm/web exec vite preview --host 0.0.0.0 --port ${PORT:-4173}'"
  }
}
